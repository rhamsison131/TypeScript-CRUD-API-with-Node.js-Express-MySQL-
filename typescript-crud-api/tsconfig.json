{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./Dist",
    "rootDir": "./Src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": ,
    "resolveJsonModule": true,
    "baseUrl": "./src",
    "paths": {
      "_helpers/*": ["_helpers/*"],
      "_middleware/*": ["_middleware/*"],
      "users/*": ["users/*"],
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "Dist"]
}